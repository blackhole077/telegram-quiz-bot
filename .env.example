# Core environment variables
DATA_DIR="data"
STORAGE_TYPE="filesystem"

# Telegram Bot settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here

# LLM settings - point at Ollama on GPU machine (LAN IP) or a hosted provider
LLM_BASE_URL=http://<gpu-machine-ip>:11434/v1
LLM_API_KEY=ollama
# Non-Reasoning Model Example
LLM_MODEL=qwen2.5vl:7b
# Reasoning Model Example
# LLM_MODEL=hengwen/DeepSeek-R1-Distill-Qwen-32B:q4_k_m
